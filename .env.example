# Karkinos runtime environment template.
# Docker Compose and direct `python -m server` both read .env. Existing non-empty
# process environment variables take precedence. Use --env-file for an explicit path.

# Optional market data provider token
TUSHARE_TOKEN=

# Server bind settings
KARKINOS_HOST=0.0.0.0
KARKINOS_PORT=8000
KARKINOS_LIVE_AUTO_START=true

# Comma-separated browser origins trusted by the API.
# Keep this local-dev scoped unless you operate a known deployment origin.
KARKINOS_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Runtime paths
KARKINOS_CONFIG_PATH=./config.json
KARKINOS_DATA_DIR=./data/store

# Market-data overrides
KARKINOS_DATA_SOURCE=akshare
KARKINOS_LIVE_POLL_INTERVAL=60

# Optional notification edge credentials. config.json stores only the channel
# type; Settings APIs expose only type/configured status.
KARKINOS_TELEGRAM_BOT_TOKEN=
KARKINOS_TELEGRAM_CHAT_ID=
KARKINOS_WECHAT_SENDKEY=

# Optional external AI boundary. These values override the typed ai group in
# config.json; blank provider/model/base URL values leave file values unchanged.
# Every network request still requires its workflow-specific human confirmation.
KARKINOS_AI_ENABLED=false
KARKINOS_AI_PROVIDER=
KARKINOS_AI_MODEL=
KARKINOS_AI_BASE_URL=
KARKINOS_AI_ADAPTER_KIND=openai_compatible_https
KARKINOS_AI_TIMEOUT_SECONDS=20
KARKINOS_AI_API_KEY=
