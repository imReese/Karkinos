# Karkinos runtime environment

# Optional market data provider token
TUSHARE_TOKEN=

# Server bind settings
KARKINOS_HOST=0.0.0.0
KARKINOS_PORT=8000

# Comma-separated browser origins trusted by the API.
# Keep this local-dev scoped unless you operate a known deployment origin.
KARKINOS_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Runtime paths
KARKINOS_CONFIG_PATH=./config.json
KARKINOS_DATA_DIR=./data/store

# Optional external AI connectivity probe. Disabled unless AI is also enabled
# in the ignored local config or KARKINOS_AI_ENABLED=true. The probe is an
# explicit non-financial POST; it never starts a research workflow.
KARKINOS_AI_ENABLED=false
KARKINOS_AI_PROVIDER=
KARKINOS_AI_MODEL=
KARKINOS_AI_BASE_URL=
KARKINOS_AI_ADAPTER_KIND=openai_compatible_https
KARKINOS_AI_TIMEOUT_SECONDS=20
KARKINOS_AI_API_KEY=
